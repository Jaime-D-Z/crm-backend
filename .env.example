# ═══════════════════════════════════════════════════════════
# CRM SYSTEM - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════

# ── Environment ────────────────────────────────────────────
NODE_ENV=development
# Options: development, production

# ── Server Configuration ───────────────────────────────────
PORT=3000
APP_NAME=CRM System

# ── URLs (REQUIRED IN PRODUCTION) ──────────────────────────
# Backend URL (your API domain)
BACKEND_URL=https://api.yourdomain.com
# Frontend URL (your React app domain)
FRONTEND_URL=https://yourdomain.com

# ── Security ───────────────────────────────────────────────
# Force HTTPS redirect in production (set to false if using Vercel/Render with automatic HTTPS)
FORCE_HTTPS=true

# ── Database (PostgreSQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_secure_password_here
DB_NAME=crm_system

# Database Pool Configuration (optional, defaults provided)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Database SSL (REQUIRED for production: AWS RDS, Neon, etc.)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Alternative: Connection string (overrides individual settings)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ── JWT Secrets (CHANGE THESE!) ────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_REFRESH_SECRET_64_CHARS_MIN
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# ── Session Secret (CHANGE THIS!) ──────────────────────────
SESSION_SECRET=CHANGE_ME_STRONG_SESSION_SECRET_64_CHARS_MIN
SESSION_MAX_AGE=28800000
# 8 hours in milliseconds

# ── Email Configuration (Nodemailer) ───────────────────────
# Gmail: Enable 2FA and create App Password
# https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=CRM System <your-email@gmail.com>

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW=900000
# 15 minutes in milliseconds
RATE_LIMIT_MAX=100
# Max requests per window
LOGIN_MAX_ATTEMPTS=5
# Max login attempts per window

# ── File Upload ────────────────────────────────────────────
UPLOAD_MAX_SIZE=2097152
# 2MB in bytes

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
# Options: error, warn, info, debug
LOG_CONSOLE=true

# ═══════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT NOTES
# ═══════════════════════════════════════════════════════════
#
# 1. NEVER commit .env file to git
# 2. Generate strong secrets using crypto.randomBytes
# 3. Use environment variables in your hosting platform:
#    - Render: Dashboard > Environment
#    - AWS EC2: /etc/environment or PM2 ecosystem
#    - Vercel: Project Settings > Environment Variables
# 4. Enable DB_SSL=true for production databases
# 5. Set FRONTEND_URL to your actual domain
# 6. Use strong passwords for DB_PASS
# 7. Enable FORCE_HTTPS=true unless your platform handles it
#
# ═══════════════════════════════════════════════════════════
