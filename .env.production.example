# Production Environment Configuration Template
# Copy this to .env in production and fill with real values

NODE_ENV=production
PORT=3000
APP_NAME=CRM System

# ── REQUIRED: Your actual domains ─────────────────────────
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Security ───────────────────────────────────────────────
FORCE_HTTPS=true

# ── Database (Production) ──────────────────────────────────
# AWS RDS / Neon / Supabase / Railway
DB_HOST=your-db-host.region.rds.amazonaws.com
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_strong_db_password
DB_NAME=crm_production
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Or use connection string:
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# ── JWT Secrets (GENERATE NEW ONES!) ───────────────────────
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_64_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_64_CHAR_SECRET_HERE
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# ── Session Secret (GENERATE NEW ONE!) ─────────────────────
SESSION_SECRET=GENERATE_64_CHAR_SECRET_HERE
SESSION_MAX_AGE=28800000

# ── Email (Production SMTP) ────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-production-email@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM=CRM System <your-production-email@gmail.com>

# ── Rate Limiting (Strict for production) ──────────────────
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
LOGIN_MAX_ATTEMPTS=5

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_CONSOLE=true
